---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

const categories = [...new Set(posts.map(p => p.data.category))];
const fmtDate = (d: string) => new Date(d + 'T00:00:00Z').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---

<Layout title="US Immigration Blog — H1B, Green Card & Visa Guides 2026" description="Expert guides on H1B lottery, EB-2 India priority dates, green card process, visa stamping, AC21 portability, and USCIS processing times.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Blog' }]} />
    <div class="mt-8 mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-3">Immigration Blog</h1>
      <p class="text-lg text-neutral-500 max-w-2xl">In-depth guides, analysis, and news on H1B, green cards, USCIS processing, and US immigration policy.</p>
    </div>

    <!-- Featured posts -->
    {posts.filter(p => p.data.featured).length > 0 && (
      <div class="mb-10">
        <h2 class="text-sm font-bold uppercase tracking-wide text-neutral-400 mb-4">Featured</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {posts.filter(p => p.data.featured).map(post => (
            <a href={`/blog/${post.id}`} class="bg-white border border-neutral-200 rounded-2xl p-6 hover:border-neutral-800 hover:shadow-md transition-all group">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-bold uppercase tracking-wide text-neutral-400">{post.data.category}</span>
                <span class="text-neutral-200">·</span>
                <span class="text-xs text-neutral-400">{fmtDate(post.data.publishDate)}</span>
              </div>
              <h2 class="text-lg font-bold text-neutral-900 mb-2 group-hover:text-neutral-700 leading-snug">{post.data.title}</h2>
              <p class="text-sm text-neutral-500 line-clamp-2">{post.data.description}</p>
              <div class="mt-4 flex flex-wrap gap-1.5">
                {post.data.tags.slice(0, 3).map(tag => (
                  <span class="text-xs bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- All posts -->
    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide text-neutral-400 mb-4">All Posts</h2>
      <div class="space-y-4">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="flex items-start gap-5 bg-white border border-neutral-200 rounded-xl p-5 hover:border-neutral-800 hover:shadow-sm transition-all group">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="text-xs font-bold bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">{post.data.category}</span>
                <span class="text-xs text-neutral-400">{fmtDate(post.data.publishDate)}</span>
              </div>
              <h2 class="text-base font-bold text-neutral-900 group-hover:text-neutral-700 mb-1">{post.data.title}</h2>
              <p class="text-sm text-neutral-500 line-clamp-1">{post.data.description}</p>
            </div>
            <span class="text-neutral-300 group-hover:text-neutral-800 transition-colors mt-1 flex-shrink-0">→</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
