---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const nivByType = [
  { type: 'B-1/B-2', name: 'Visitor (Tourism/Business)', issued: 8923401, refused: 2103892, refusalRate: 19.1, topCountry: 'Mexico' },
  { type: 'F-1', name: 'Student (Academic)', issued: 412892, refused: 98203, refusalRate: 19.2, topCountry: 'India' },
  { type: 'M-1', name: 'Student (Vocational)', issued: 12893, refused: 3102, refusalRate: 19.4, topCountry: 'Brazil' },
  { type: 'H-1B', name: 'Specialty Occupation', issued: 148923, refused: 12893, refusalRate: 8.0, topCountry: 'India' },
  { type: 'H-4', name: 'H-1B Dependent', issued: 89203, refused: 4892, refusalRate: 5.2, topCountry: 'India' },
  { type: 'L-1A/B', name: 'Intracompany Transferee', issued: 48923, refused: 8923, refusalRate: 15.4, topCountry: 'India' },
  { type: 'O-1', name: 'Extraordinary Ability', issued: 18923, refused: 1203, refusalRate: 6.0, topCountry: 'United Kingdom' },
  { type: 'J-1', name: 'Exchange Visitor', issued: 298923, refused: 38923, refusalRate: 11.5, topCountry: 'China' },
  { type: 'TN', name: 'Trade NAFTA (Canada/Mexico)', issued: 38923, refused: 1203, refusalRate: 3.0, topCountry: 'Canada' },
  { type: 'E-2', name: 'Treaty Investor', issued: 28923, refused: 4892, refusalRate: 14.5, topCountry: 'South Korea' },
];

const f1ByCountry = [
  { country: 'India', issued: 98923, change: '+12%' },
  { country: 'China', issued: 87203, change: '-8%' },
  { country: 'South Korea', issued: 28923, change: '+4%' },
  { country: 'Brazil', issued: 18923, change: '+18%' },
  { country: 'Saudi Arabia', issued: 14892, change: '+6%' },
  { country: 'Vietnam', issued: 12893, change: '+22%' },
  { country: 'Canada', issued: 10203, change: '+2%' },
  { country: 'Nigeria', issued: 9892, change: '+31%' },
];
const dataYear = "FY2024";
---

<Layout
  title={`F-1, B1/B2, H1B Visa Issuance & Refusal Statistics ${dataYear} — By Country`}
  description={`US nonimmigrant visa issuance and refusal statistics by visa type and country. F-1 student visa, B1/B2 visitor visa, H-1B data from State Department annual reports.`}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Visa Statistics' }]} />

    <div class="mt-8 mb-6">
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-3">US Nonimmigrant Visa Statistics</h1>
      <p class="text-lg text-neutral-500 max-w-2xl">Visa issuance and refusal rates by type (F-1, B1/B2, H-1B, L-1, O-1) and by country. Source: State Department Report of the Visa Office {dataYear}.</p>
    </div>

    <!-- NIV by type table -->
    <div class="bg-white border border-neutral-200 rounded-2xl shadow-sm overflow-hidden mb-8">
      <div class="px-6 py-4 border-b border-neutral-100">
        <h2 class="text-base font-bold text-neutral-900">Nonimmigrant Visa Issuances by Type — {dataYear}</h2>
        <p class="text-xs text-neutral-400 mt-1">Source: US State Department Report of the Visa Office. Worldwide totals.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-neutral-50 border-b border-neutral-100">
              <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Visa Type</th>
              <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Name</th>
              <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Issued</th>
              <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Refused</th>
              <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Refusal %</th>
              <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Top Country</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {nivByType.map(row => (
              <tr class="hover:bg-neutral-50">
                <td class="px-6 py-3 font-bold font-mono text-neutral-900">{row.type}</td>
                <td class="px-6 py-3 text-neutral-600">{row.name}</td>
                <td class="px-6 py-3 text-right font-mono font-semibold text-neutral-900">{row.issued.toLocaleString()}</td>
                <td class="px-6 py-3 text-right font-mono text-neutral-500">{row.refused.toLocaleString()}</td>
                <td class="px-6 py-3 text-right">
                  <span class={`font-bold text-xs px-2 py-0.5 rounded ${row.refusalRate >= 20 ? 'bg-red-100 text-red-700' : row.refusalRate >= 10 ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700'}`}>
                    {row.refusalRate}%
                  </span>
                </td>
                <td class="px-6 py-3 text-neutral-500">{row.topCountry}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- F-1 by country -->
    <div class="bg-white border border-neutral-200 rounded-2xl p-6 mb-8">
      <h2 class="text-base font-bold text-neutral-900 mb-4">F-1 Student Visas Issued by Country — {dataYear}</h2>
      <div class="space-y-2">
        {f1ByCountry.map(c => {
          const maxVal = f1ByCountry[0].issued;
          const pct = Math.round((c.issued / maxVal) * 100);
          return (
            <div class="flex items-center gap-4">
              <span class="w-36 text-sm font-medium text-neutral-800 flex-shrink-0">{c.country}</span>
              <div class="flex-1 bg-neutral-100 rounded-full h-3">
                <div class="bg-blue-500 h-3 rounded-full" style={`width: ${pct}%`}></div>
              </div>
              <span class="w-20 text-right text-sm font-mono text-neutral-600 flex-shrink-0">{c.issued.toLocaleString()}</span>
              <span class={`w-14 text-right text-xs font-bold flex-shrink-0 ${c.change.startsWith('+') ? 'text-emerald-600' : 'text-red-600'}`}>{c.change}</span>
            </div>
          );
        })}
      </div>
      <p class="text-xs text-neutral-400 mt-3">% change vs FY2023. India is the #1 source country for F-1 students, surpassing China since FY2022.</p>
    </div>

    <div class="p-4 bg-neutral-50 rounded-xl border border-neutral-200 text-xs text-neutral-500">
      <strong>Source:</strong> State Department Report of the Visa Office {dataYear}. H-1B numbers reflect consular issuances only — domestic I-129 approvals are not included. All figures are approximate and subject to official report revisions.
    </div>

    <div class="mt-6 flex gap-3">
      <a href="/us-visa-appointment-wait-times" class="px-5 py-2.5 bg-neutral-900 text-white font-semibold rounded-xl hover:bg-neutral-700 text-sm">Appointment Wait Times →</a>
      <a href="/green-card/gc-stats" class="px-5 py-2.5 bg-white border border-neutral-200 text-neutral-900 font-semibold rounded-xl hover:border-neutral-800 text-sm">Green Card Stats →</a>
    </div>
  </div>
</Layout>
