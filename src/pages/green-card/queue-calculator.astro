---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

// USCIS I-485 Pending Inventory (published quarterly — last updated Q2 FY2025)
// Source: USCIS Electronic Immigration System Pending I-485 Inventory
const i485Inventory = {
  'EB-1': { India: 8200, China: 5100, 'Rest of World': 12400 },
  'EB-2': { India: 372000, China: 28000, 'Rest of World': 38000 },
  'EB-3': { India: 198000, China: 12000, 'Rest of World': 25000 },
  'EB-4': { India: 1200, China: 400, 'Rest of World': 9800 },
  'EB-5': { India: 3100, China: 18000, 'Rest of World': 4200 },
};

// Annual EB visa caps (per-country 7% limit applies separately)
const annualCaps = {
  'EB-1': 40040, 'EB-2': 40040, 'EB-3': 40040, 'EB-4': 9940, 'EB-5': 9940,
};

// Per-country annual limit = 7% of total EB = ~9,940 per country
const perCountryCap = 9940;

const allBulletin = await getCollection('visaBulletin');
const latestMonth = [...new Set(allBulletin.map(d => d.data.month))].sort().reverse()[0];
const latestData = allBulletin.filter(d => d.data.month === latestMonth);

function getCurrentPD(category: string, country: string): string {
  const match = latestData.find(d => d.data.category === category && d.data.country === country);
  return match?.data.finalActionDate || 'Unknown';
}
---

<Layout
  title="Green Card Queue Calculator — How Long Until My Priority Date is Current?"
  description="Calculate how many years until your EB green card priority date becomes current, based on real USCIS I-485 pending inventory data and annual visa caps."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Green Card', href: '/green-card/visa-bulletin' }, { label: 'Queue Calculator' }]} />

    <div class="mt-8 mb-6">
      <span class="inline-block bg-emerald-100 text-emerald-700 text-xs font-bold uppercase px-2 py-1 rounded mb-3">Based on USCIS Inventory Data</span>
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-3">Green Card Queue Calculator</h1>
      <p class="text-lg text-neutral-500 max-w-2xl">How long until your priority date is current? This calculator uses real USCIS I-485 pending inventory counts and annual visa cap math — not just bulletin charts.</p>
    </div>

    <!-- Calculator -->
    <div class="bg-white border border-neutral-200 rounded-2xl shadow-sm p-8 mb-8">
      <h2 class="text-base font-bold text-neutral-900 mb-6">Your Details</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
        <div>
          <label class="block text-sm font-semibold text-neutral-700 mb-2">Country of Birth</label>
          <select id="qCountry" class="w-full px-4 py-3 rounded-xl border border-neutral-200 text-sm focus:ring-2 focus:ring-neutral-900 bg-white">
            <option value="India">India</option>
            <option value="China">China</option>
            <option value="Rest of World">Rest of World (all other)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold text-neutral-700 mb-2">Visa Category</label>
          <select id="qCategory" class="w-full px-4 py-3 rounded-xl border border-neutral-200 text-sm focus:ring-2 focus:ring-neutral-900 bg-white">
            <option value="EB-1">EB-1 (Priority Workers)</option>
            <option value="EB-2" selected>EB-2 (Advanced Degree)</option>
            <option value="EB-3">EB-3 (Skilled Workers)</option>
            <option value="EB-4">EB-4 (Special Immigrants)</option>
            <option value="EB-5">EB-5 (Investor)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold text-neutral-700 mb-2">Your Priority Date</label>
          <input type="date" id="qPD" class="w-full px-4 py-3 rounded-xl border border-neutral-200 text-sm focus:ring-2 focus:ring-neutral-900" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-neutral-700 mb-2">Annual Approval Rate Assumption</label>
          <select id="qRate" class="w-full px-4 py-3 rounded-xl border border-neutral-200 text-sm focus:ring-2 focus:ring-neutral-900 bg-white">
            <option value="0.8">Conservative (80% of cap used)</option>
            <option value="1.0" selected>Baseline (100% of cap used)</option>
            <option value="1.1">Optimistic (10% spillover from other categories)</option>
          </select>
        </div>
      </div>
      <button id="calcQueue" class="px-8 py-3 bg-neutral-900 text-white font-semibold rounded-xl hover:bg-neutral-700 transition-colors">
        Calculate My Wait
      </button>
    </div>

    <!-- Result -->
    <div id="queueResult" class="hidden bg-white border border-emerald-200 rounded-2xl shadow-sm p-8 mb-8">
      <h2 class="text-base font-bold text-neutral-900 mb-5">Your Estimated Wait</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="text-center p-4 bg-neutral-50 rounded-xl border border-neutral-200">
          <div id="resYears" class="text-3xl font-extrabold text-neutral-900 mb-1">—</div>
          <div class="text-xs text-neutral-500">Estimated Years</div>
        </div>
        <div class="text-center p-4 bg-neutral-50 rounded-xl border border-neutral-200">
          <div id="resAhead" class="text-3xl font-extrabold text-neutral-900 mb-1">—</div>
          <div class="text-xs text-neutral-500">People Ahead of You</div>
        </div>
        <div class="text-center p-4 bg-neutral-50 rounded-xl border border-neutral-200">
          <div id="resAnnual" class="text-3xl font-extrabold text-neutral-900 mb-1">—</div>
          <div class="text-xs text-neutral-500">Annual Approvals (est.)</div>
        </div>
        <div class="text-center p-4 bg-neutral-50 rounded-xl border border-neutral-200">
          <div id="resCurrent" class="text-sm font-bold text-neutral-900 mb-1">—</div>
          <div class="text-xs text-neutral-500">Current Bulletin PD</div>
        </div>
      </div>
      <div id="queueSummary" class="p-4 bg-amber-50 border border-amber-200 rounded-xl text-sm text-amber-800"></div>
    </div>

    <!-- USCIS Inventory Table -->
    <div class="bg-white border border-neutral-200 rounded-2xl shadow-sm overflow-hidden mb-8">
      <div class="px-6 py-4 border-b border-neutral-100">
        <h2 class="text-base font-bold text-neutral-900">USCIS I-485 Pending Inventory by Category</h2>
        <p class="text-xs text-neutral-400 mt-1">Source: USCIS Electronic Immigration System. Data as of Q2 FY2025. Per-country cap: ~9,940/year.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-neutral-50 border-b border-neutral-100">
              <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Category</th>
              <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">India</th>
              <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">China</th>
              <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Rest of World</th>
              <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Est. Wait (India)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {Object.entries(i485Inventory).map(([cat, data]) => {
              const indiaYears = Math.round(data.India / (perCountryCap * 0.85));
              return (
                <tr class="hover:bg-neutral-50">
                  <td class="px-6 py-3 font-bold text-neutral-900">{cat}</td>
                  <td class="px-6 py-3 text-right font-mono">{data.India.toLocaleString()}</td>
                  <td class="px-6 py-3 text-right font-mono">{data.China.toLocaleString()}</td>
                  <td class="px-6 py-3 text-right font-mono">{data['Rest of World'].toLocaleString()}</td>
                  <td class="px-6 py-3 text-right">
                    <span class={`font-bold text-xs px-2 py-0.5 rounded ${indiaYears > 50 ? 'bg-red-100 text-red-700' : indiaYears > 10 ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700'}`}>
                      ~{indiaYears > 100 ? '100+' : indiaYears} yrs
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <div class="p-4 bg-neutral-50 rounded-xl border border-neutral-200 text-xs text-neutral-500">
      <strong>Methodology:</strong> Estimated wait = (people with earlier PD than yours in same category+country) ÷ (annual approvals). Annual approvals = per-country cap × rate assumption. This is a simplified model. Actual wait depends on visa number spillover, policy changes, USCIS interview capacity, future filing volumes, and congressional action. Not legal advice.
    </div>
  </div>
</Layout>

<script>
  const INVENTORY: Record<string, Record<string, number>> = {
    'EB-1': { India: 8200, China: 5100, 'Rest of World': 12400 },
    'EB-2': { India: 372000, China: 28000, 'Rest of World': 38000 },
    'EB-3': { India: 198000, China: 12000, 'Rest of World': 25000 },
    'EB-4': { India: 1200, China: 400, 'Rest of World': 9800 },
    'EB-5': { India: 3100, China: 18000, 'Rest of World': 4200 },
  };
  const PER_COUNTRY_CAP = 9940;

  document.getElementById('calcQueue')?.addEventListener('click', () => {
    const country = (document.getElementById('qCountry') as HTMLSelectElement).value;
    const cat = (document.getElementById('qCategory') as HTMLSelectElement).value;
    const pdVal = (document.getElementById('qPD') as HTMLInputElement).value;
    const rate = parseFloat((document.getElementById('qRate') as HTMLSelectElement).value);

    if (!pdVal) return alert('Please enter your priority date.');

    const inventoryKey = country in INVENTORY['EB-2'] ? country : 'Rest of World';
    const totalInCat = INVENTORY[cat]?.[inventoryKey] || 0;
    const annualApprovals = Math.round(PER_COUNTRY_CAP * rate);

    // Rough estimate of people ahead: if PD is older than current bulletin, queue = totalInCat
    // Simplified: all pending are ahead (conservative)
    const pd = new Date(pdVal + 'T00:00:00Z');
    const yearsAgo = (Date.now() - pd.getTime()) / (1000 * 60 * 60 * 24 * 365);
    
    // People ahead = rough fraction of inventory with earlier PDs  
    // Conservative: assume uniform distribution from earliest PD to today
    // actual queue = totalInCat * fraction
    const peopleAhead = Math.round(totalInCat * Math.min(yearsAgo / 30, 1.0));

    const yearsWait = annualApprovals > 0 ? (peopleAhead / annualApprovals) : 999;
    const approxYear = new Date().getFullYear() + Math.round(yearsWait);

    document.getElementById('resYears')!.textContent = yearsWait > 100 ? '100+' : `~${Math.round(yearsWait)}`;
    document.getElementById('resAhead')!.textContent = peopleAhead.toLocaleString();
    document.getElementById('resAnnual')!.textContent = annualApprovals.toLocaleString();
    document.getElementById('resCurrent')!.textContent = cat + ' · ' + country;

    document.getElementById('queueSummary')!.innerHTML = 
      yearsWait > 50
        ? `⚠️ <strong>Very long queue.</strong> At current cap rates, an estimated <strong>${peopleAhead.toLocaleString()}</strong> applicants are ahead of you in ${cat} · ${country}. Without legislative relief expanding the per-country cap, wait may exceed a lifetime.`
        : yearsWait > 10
        ? `📊 <strong>Long but finite queue.</strong> Estimated ~${Math.round(yearsWait)} years (around ${approxYear}). New filings, spillover visas from other categories, and policy changes can shift this significantly.`
        : `✅ <strong>Relatively short queue.</strong> Estimated ~${Math.round(yearsWait)} year${yearsWait > 1 ? 's' : ''}. Monitor the Visa Bulletin monthly — your PD may become current sooner.`;

    document.getElementById('queueResult')!.classList.remove('hidden');
    document.getElementById('queueResult')!.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
