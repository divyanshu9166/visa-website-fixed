---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const resources = [
  { href: '/resources/how-to-read-visa-bulletin', title: 'How to Read the Visa Bulletin', desc: 'Final Action Dates vs Dates for Filing, C vs U, all EB categories explained.', icon: '📖' },
  { href: '/resources/h1b-layoff-guide', title: 'H1B Layoff Guide — 60-Day Grace Period', desc: "What to do if you're laid off on H1B. 60-day grace period, H1B transfer, AC21, options.", icon: '⚠️' },
  { href: '/resources/ac21-portability', title: 'AC21 Job Portability Guide', desc: 'Change jobs after 180 days of I-485 pending without losing your green card priority date.', icon: '💼' },
  { href: '/green-card/dos-predictions', title: 'DOS Visa Bulletin Predictions', desc: 'Monthly State Department commentary on expected priority date movement.', icon: '🔮' },
  { href: '/green-card/gc-stats', title: 'Green Card Statistics', desc: 'How many green cards issued by category and country, FY2021–FY2024.', icon: '📊' },
  { href: '/visa-stats', title: 'Nonimmigrant Visa Statistics', desc: 'F-1, B1/B2, H-1B issuance and refusal rates by country — State Dept data.', icon: '📈' },
];
---

<Layout title="US Immigration Resources & Guides — Visa Bulletin, H1B, Green Card" description="Free immigration guides: how to read the visa bulletin, H1B layoff guide, AC21 portability, green card statistics, and more.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Resources' }]} />
    <div class="mt-8 mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-3">Immigration Resources & Guides</h1>
      <p class="text-lg text-neutral-500 max-w-2xl">Plain-English guides to the US immigration process — from reading the Visa Bulletin to handling a layoff on H1B.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {resources.map(r => (
        <a href={r.href} class="bg-white border border-neutral-200 rounded-xl p-6 hover:border-neutral-800 hover:shadow-md transition-all group flex gap-4">
          <span class="text-2xl flex-shrink-0">{r.icon}</span>
          <div>
            <h2 class="text-base font-bold text-neutral-900 group-hover:text-neutral-700 mb-1">{r.title}</h2>
            <p class="text-sm text-neutral-500">{r.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
