---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import DisqusComments from '../../components/DisqusComments.astro';
import { PrismaClient } from '@prisma/client';

export async function getStaticPaths() {
  const prisma = new PrismaClient();
  const employers = await prisma.lcaEmployer.findMany({
    orderBy: { totalLCAs: 'desc' },
    take: 500
  });
  return employers.map(e => ({ params: { employer: e.slug }, props: { employer: e } }));
}

const { employer } = Astro.props;
const d = employer as any;

const gradeColor: Record<string, string> = {
  A: 'bg-emerald-100 text-emerald-700 border-emerald-200',
  B: 'bg-blue-100 text-blue-700 border-blue-200',
  C: 'bg-amber-100 text-amber-700 border-amber-200',
  D: 'bg-orange-100 text-orange-700 border-orange-200',
  F: 'bg-red-100 text-red-700 border-red-200',
};

const levelColors = ['bg-red-400', 'bg-amber-400', 'bg-blue-500', 'bg-emerald-500'];
const levelLabels = ['Level I', 'Level II', 'Level III', 'Level IV'];
const levelPcts = [d.wageLevelDist.L1, d.wageLevelDist.L2, d.wageLevelDist.L3, d.wageLevelDist.L4];
---

<Layout
  title={`${d.employerName} H1B Sponsorship Data — Salary, Approval Rate & LCA Records`}
  description={`${d.employerName} H1B data: ${d.totalLCAs.toLocaleString()} LCAs in FY${d.fiscalYear}, ${d.approvalRate}% approval rate, avg salary $${(d.avgWage/1000).toFixed(0)}K. Grade: ${d.grade}.`}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'H1B Database', href: '/h1b' }, { label: d.employerName }]} />

    <div class="mt-8 mb-6 flex items-start justify-between gap-4">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900 mb-2">{d.employerName}</h1>
        <p class="text-neutral-500 text-sm">H-1B LCA Data · FY{d.fiscalYear} · Source: DOL Public Disclosure</p>
      </div>
      <span class={`text-4xl font-extrabold px-4 py-2 rounded-xl border-2 flex-shrink-0 ${gradeColor[d.grade]}`}>{d.grade}</span>
    </div>

    <!-- Key stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      {[
        { label: 'Total LCAs', value: d.totalLCAs.toLocaleString() },
        { label: 'Approval Rate', value: `${d.approvalRate}%`, highlight: d.approvalRate >= 95 },
        { label: 'Avg Salary', value: `$${(d.avgWage/1000).toFixed(0)}K` },
        { label: 'Median Salary', value: `$${(d.medianWage/1000).toFixed(0)}K` },
      ].map(s => (
        <div class="bg-white border border-neutral-200 rounded-xl p-4 text-center">
          <div class={`text-2xl font-extrabold mb-0.5 ${s.highlight ? 'text-emerald-600' : 'text-neutral-900'}`}>{s.value}</div>
          <div class="text-xs text-neutral-500">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Wage level distribution -->
    <div class="bg-white border border-neutral-200 rounded-2xl p-6 mb-6">
      <h2 class="text-base font-bold text-neutral-900 mb-4">Wage Level Distribution</h2>
      <div class="flex rounded-xl overflow-hidden h-8 mb-4">
        {levelPcts.map((pct, i) => pct > 0 && (
          <div class={`${levelColors[i]} flex items-center justify-center text-white text-xs font-bold`} style={`width: ${pct}%`}>
            {pct >= 8 ? `${pct}%` : ''}
          </div>
        ))}
      </div>
      <div class="grid grid-cols-4 gap-2">
        {levelLabels.map((label, i) => (
          <div class="text-center">
            <div class={`w-3 h-3 rounded-full ${levelColors[i]} mx-auto mb-1`}></div>
            <div class="text-xs font-semibold text-neutral-700">{label}</div>
            <div class="text-sm font-bold text-neutral-900">{levelPcts[i]}%</div>
          </div>
        ))}
      </div>
      <p class="text-xs text-neutral-400 mt-3">
        {d.wageLevelDist.L3 + d.wageLevelDist.L4 >= 60
          ? `✅ ${d.wageLevelDist.L3 + d.wageLevelDist.L4}% of LCAs are Level III-IV — strong odds under the FY2027 wage-weighted lottery.`
          : d.wageLevelDist.L1 + d.wageLevelDist.L2 >= 70
          ? `⚠️ ${d.wageLevelDist.L1 + d.wageLevelDist.L2}% of LCAs are Level I-II — lower odds under the proposed wage-weighted lottery.`
          : `Mixed wage level distribution. See our H1B lottery calculator for odds by level.`}
      </p>
    </div>

    <!-- Top job titles -->
    <div class="bg-white border border-neutral-200 rounded-2xl shadow-sm overflow-hidden mb-6">
      <div class="px-6 py-4 border-b border-neutral-100">
        <h2 class="text-base font-bold text-neutral-900">Top Job Titles at {d.employerName}</h2>
      </div>
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-neutral-50 border-b border-neutral-100">
            <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Title</th>
            <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">LCAs</th>
            <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Avg Wage</th>
            <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">SOC</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
          {d.topTitles.map((t: any) => (
            <tr class="hover:bg-neutral-50">
              <td class="px-6 py-3 font-medium text-neutral-900">{t.title}</td>
              <td class="px-6 py-3 text-right font-mono text-neutral-600">{t.count.toLocaleString()}</td>
              <td class="px-6 py-3 text-right font-mono font-semibold text-neutral-900">${(t.avgWage/1000).toFixed(0)}K</td>
              <td class="px-6 py-3 text-neutral-400 font-mono text-xs">{t.socCode}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Top states -->
    <div class="bg-white border border-neutral-200 rounded-2xl p-6 mb-6">
      <h2 class="text-base font-bold text-neutral-900 mb-4">LCA Filings by State</h2>
      <div class="space-y-2">
        {d.topStates.map((s: any) => {
          const maxCount = d.topStates[0].count;
          const pct = Math.round((s.count / maxCount) * 100);
          return (
            <div class="flex items-center gap-3">
              <span class="w-8 text-xs font-bold text-neutral-500 text-right flex-shrink-0">{s.state}</span>
              <div class="flex-1 bg-neutral-100 rounded-full h-2">
                <div class="bg-neutral-900 h-2 rounded-full" style={`width: ${pct}%`}></div>
              </div>
              <span class="text-xs font-mono text-neutral-500 w-16 text-right flex-shrink-0">{s.count.toLocaleString()}</span>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Does this employer sponsor H1B? CTA -->
    <div class="bg-blue-50 border border-blue-200 rounded-2xl p-5 mb-8">
      <h3 class="font-bold text-blue-900 mb-1">Does {d.employerName} sponsor H-1B visas?</h3>
      <p class="text-sm text-blue-800">Yes — {d.employerName} filed <strong>{d.totalLCAs.toLocaleString()}</strong> H-1B LCAs in FY{d.fiscalYear} with a <strong>{d.approvalRate}%</strong> approval rate. They are an active H-1B sponsor. The most common role is <strong>{d.topTitles[0]?.title}</strong> at an average wage of <strong>${(d.topTitles[0]?.avgWage / 1000).toFixed(0)}K</strong>.</p>
    </div>

    <div class="flex gap-3 mb-8">
      <a href="/h1b" class="px-5 py-2.5 bg-neutral-900 text-white font-semibold rounded-xl hover:bg-neutral-700 text-sm">← All Employers</a>
      <a href="/tools/h1b-lottery-calculator" class="px-5 py-2.5 bg-white border border-neutral-200 text-neutral-900 font-semibold rounded-xl hover:border-neutral-800 text-sm">H1B Lottery Odds →</a>
    </div>

    <DisqusComments pageIdentifier={`h1b-employer-${d.slug}`} title={`${d.employerName} H1B Discussion`} />
  </div>
</Layout>
