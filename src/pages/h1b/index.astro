---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const employers = await getCollection('lca');
employers.sort((a, b) => b.data.totalLCAs - a.data.totalLCAs);

const totalLCAs = employers.reduce((s, e) => s + e.data.totalLCAs, 0);
const gradeColor: Record<string, string> = {
  A: 'bg-emerald-100 text-emerald-700',
  B: 'bg-blue-100 text-blue-700',
  C: 'bg-amber-100 text-amber-700',
  D: 'bg-orange-100 text-orange-700',
  F: 'bg-red-100 text-red-700',
};

const popularTitles = [
  { title: 'Software Engineer', slug: 'software-engineer' },
  { title: 'Senior Software Engineer', slug: 'senior-software-engineer' },
  { title: 'Data Scientist', slug: 'data-scientist' },
  { title: 'Product Manager', slug: 'product-manager' },
  { title: 'Machine Learning Engineer', slug: 'machine-learning-engineer' },
  { title: 'Solutions Architect', slug: 'solutions-architect' },
  { title: 'Research Scientist', slug: 'research-scientist' },
  { title: 'Data Engineer', slug: 'data-engineer' },
];
---

<Layout
  title="H1B Sponsor Database — Salary, Approval Rates & LCA Data 2024"
  description="Search H1B employer sponsorship data: LCA salary ranges, approval rates, wage levels, and top job titles. Free database from DOL LCA disclosure data FY2024."
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'H1B Sponsors & Salaries' }]} />

    <div class="mt-8 mb-8">
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-3">H-1B Sponsor & Salary Database</h1>
      <p class="text-lg text-neutral-500 max-w-2xl">Search employer sponsorship data, salary ranges, and LCA approval rates from DOL public disclosure data. FY2024 dataset.</p>
    </div>

    <!-- Stats bar -->
    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="bg-white border border-neutral-200 rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-neutral-900">{totalLCAs.toLocaleString()}+</div>
        <div class="text-xs text-neutral-500 mt-0.5">LCA Records</div>
      </div>
      <div class="bg-white border border-neutral-200 rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-neutral-900">{employers.length.toLocaleString()}+</div>
        <div class="text-xs text-neutral-500 mt-0.5">Employers</div>
      </div>
      <div class="bg-white border border-neutral-200 rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-neutral-900">FY2024</div>
        <div class="text-xs text-neutral-500 mt-0.5">Data Year</div>
      </div>
    </div>

    <!-- Search -->
    <div class="bg-white border border-neutral-200 rounded-2xl p-6 mb-8">
      <label class="block text-sm font-semibold text-neutral-700 mb-2">Search Employer</label>
      <div class="flex gap-3">
        <input id="empSearch" type="text" placeholder="e.g. Google, Amazon, Infosys..." class="flex-1 px-4 py-3 rounded-xl border border-neutral-200 text-sm focus:ring-2 focus:ring-neutral-900" />
        <button id="empSearchBtn" class="px-6 py-3 bg-neutral-900 text-white font-semibold rounded-xl hover:bg-neutral-700 transition-colors">Search</button>
      </div>
    </div>

    <!-- Browse by job title -->
    <div class="mb-8">
      <h2 class="text-sm font-bold uppercase tracking-wide text-neutral-400 mb-3">Browse by Job Title</h2>
      <div class="flex flex-wrap gap-2">
        {popularTitles.map(t => (
          <a href={`/h1b/salary/${t.slug}`} class="px-3 py-1.5 bg-white border border-neutral-200 text-sm text-neutral-700 rounded-lg hover:border-neutral-800 hover:bg-neutral-50 transition-colors">{t.title}</a>
        ))}
      </div>
    </div>

    <!-- Top employers table -->
    <div class="bg-white border border-neutral-200 rounded-2xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-neutral-100">
        <h2 class="text-base font-bold text-neutral-900">Top H1B Sponsors — FY2024</h2>
        <p class="text-xs text-neutral-400 mt-0.5">Source: DOL LCA Disclosure Data. Grade = function of approval rate + wage level distribution.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="empTable">
          <thead>
            <tr class="bg-neutral-50 border-b border-neutral-100">
              <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Employer</th>
              <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">LCAs</th>
              <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Approval %</th>
              <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Avg Salary</th>
              <th class="text-center px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Grade</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100" id="empTableBody">
            {employers.map(e => (
              <tr class="hover:bg-neutral-50 emp-row" data-name={e.data.employerName.toLowerCase()}>
                <td class="px-6 py-3 font-semibold text-neutral-900">{e.data.employerName}</td>
                <td class="px-6 py-3 text-right font-mono text-neutral-600">{e.data.totalLCAs.toLocaleString()}</td>
                <td class="px-6 py-3 text-right">
                  <span class={`font-semibold ${e.data.approvalRate >= 95 ? 'text-emerald-600' : e.data.approvalRate >= 88 ? 'text-amber-600' : 'text-red-600'}`}>
                    {e.data.approvalRate}%
                  </span>
                </td>
                <td class="px-6 py-3 text-right font-mono font-semibold text-neutral-900">${(e.data.avgWage / 1000).toFixed(0)}K</td>
                <td class="px-6 py-3 text-center">
                  <span class={`inline-block text-xs font-extrabold px-2 py-0.5 rounded ${gradeColor[e.data.grade] || 'bg-neutral-100 text-neutral-600'}`}>
                    {e.data.grade}
                  </span>
                </td>
                <td class="px-6 py-3 text-right">
                  <a href={`/h1b/${e.data.slug}`} class="text-xs font-semibold text-neutral-400 hover:text-neutral-900 transition-colors">View →</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Grade explanation -->
    <div class="mt-6 bg-white border border-neutral-200 rounded-xl p-5">
      <h3 class="text-sm font-bold text-neutral-900 mb-3">Employer Grade Explained</h3>
      <div class="flex flex-wrap gap-3 text-xs">
        {Object.entries(gradeColor).map(([g, cls]) => (
          <div class="flex items-center gap-2">
            <span class={`font-extrabold px-2 py-0.5 rounded ${cls}`}>{g}</span>
            <span class="text-neutral-500">{g === 'A' ? '≥95% approval, mostly L3-L4 wages' : g === 'B' ? '90-94% approval, mixed wages' : g === 'C' ? '85-89% approval, L1-L2 heavy' : g === 'D' ? '80-84% approval' : '<80% approval'}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('empSearch') as HTMLInputElement;
  const searchBtn = document.getElementById('empSearchBtn');

  function filterTable() {
    const q = searchInput.value.trim().toLowerCase();
    document.querySelectorAll('.emp-row').forEach(row => {
      const r = row as HTMLElement;
      r.style.display = !q || r.dataset.name?.includes(q) ? '' : 'none';
    });
  }

  searchBtn?.addEventListener('click', filterTable);
  searchInput?.addEventListener('keyup', (e) => { if (e.key === 'Enter') filterTable(); });
  searchInput?.addEventListener('input', filterTable);
</script>
