---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const titleSlugMap: Record<string, string> = {
    'software-engineer': 'Software Engineer',
    'senior-software-engineer': 'Senior Software Engineer',
    'data-scientist': 'Data Scientist',
    'product-manager': 'Product Manager',
    'machine-learning-engineer': 'Machine Learning Engineer',
    'solutions-architect': 'Solutions Architect',
    'research-scientist': 'Research Scientist',
    'data-engineer': 'Data Engineer',
  };
  return Object.keys(titleSlugMap).map(slug => ({ params: { title: slug }, props: { titleLabel: titleSlugMap[slug] } }));
}

const { title } = Astro.params;
const { titleLabel } = Astro.props;

const employers = await getCollection('lca');

// Aggregate salary data for this title across all employers
type TitleMatch = { employer: string; slug: string; count: number; avgWage: number; };
const matches: TitleMatch[] = [];

for (const emp of employers) {
  for (const t of emp.data.topTitles) {
    if (t.title.toLowerCase() === titleLabel.toLowerCase()) {
      matches.push({ employer: emp.data.employerName, slug: emp.data.slug, count: t.count, avgWage: t.avgWage });
    }
  }
}

matches.sort((a, b) => b.count - a.count);

const allWages = matches.map(m => m.avgWage);
const overallAvg = allWages.length ? Math.round(allWages.reduce((s, w) => s + w, 0) / allWages.length) : 0;
const minWage = allWages.length ? Math.min(...allWages) : 0;
const maxWage = allWages.length ? Math.max(...allWages) : 0;
const totalLCAs = matches.reduce((s, m) => s + m.count, 0);
---

<Layout
  title={`${titleLabel} H1B Salary — Average, Median & Range by Employer`}
  description={`${titleLabel} H1B salary data: average $${(overallAvg/1000).toFixed(0)}K, range $${(minWage/1000).toFixed(0)}K–$${(maxWage/1000).toFixed(0)}K. See which employers pay the most and sponsor the most ${titleLabel} H1B visas.`}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'H1B Database', href: '/h1b' }, { label: `${titleLabel} Salary` }]} />

    <div class="mt-8 mb-6">
      <h1 class="text-4xl font-extrabold tracking-tight text-neutral-900 mb-3">{titleLabel} — H-1B Salary & Sponsorship Data</h1>
      <p class="text-lg text-neutral-500 max-w-2xl">LCA salary data for <strong>{titleLabel}</strong> across major H-1B sponsors. Based on DOL public disclosure data FY2024.</p>
    </div>

    <!-- Salary overview -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white border border-neutral-200 rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-neutral-900">${(overallAvg/1000).toFixed(0)}K</div>
        <div class="text-xs text-neutral-500">Average Salary</div>
      </div>
      <div class="bg-white border border-neutral-200 rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-emerald-600">${(maxWage/1000).toFixed(0)}K</div>
        <div class="text-xs text-neutral-500">Highest Employer Avg</div>
      </div>
      <div class="bg-white border border-neutral-200 rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-neutral-600">${(minWage/1000).toFixed(0)}K</div>
        <div class="text-xs text-neutral-500">Lowest Employer Avg</div>
      </div>
      <div class="bg-white border border-neutral-200 rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-neutral-900">{totalLCAs.toLocaleString()}</div>
        <div class="text-xs text-neutral-500">Total LCAs</div>
      </div>
    </div>

    {matches.length > 0 ? (
      <div class="bg-white border border-neutral-200 rounded-2xl shadow-sm overflow-hidden mb-8">
        <div class="px-6 py-4 border-b border-neutral-100">
          <h2 class="text-base font-bold text-neutral-900">Salary by Employer — {titleLabel}</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-neutral-50 border-b border-neutral-100">
                <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Employer</th>
                <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">LCAs</th>
                <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Avg Salary</th>
                <th class="px-6 py-3 text-xs font-bold uppercase tracking-wide text-neutral-500">Salary Bar</th>
                <th class="px-6 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
              {matches.map(m => {
                const barPct = maxWage > 0 ? Math.round((m.avgWage / maxWage) * 100) : 0;
                return (
                  <tr class="hover:bg-neutral-50">
                    <td class="px-6 py-3 font-semibold text-neutral-900">{m.employer}</td>
                    <td class="px-6 py-3 text-right font-mono text-neutral-600">{m.count.toLocaleString()}</td>
                    <td class="px-6 py-3 text-right font-mono font-bold text-neutral-900">${(m.avgWage/1000).toFixed(0)}K</td>
                    <td class="px-6 py-3 w-32">
                      <div class="bg-neutral-100 rounded-full h-2">
                        <div class="bg-neutral-900 h-2 rounded-full" style={`width: ${barPct}%`}></div>
                      </div>
                    </td>
                    <td class="px-6 py-3">
                      <a href={`/h1b/${m.slug}`} class="text-xs font-semibold text-neutral-400 hover:text-neutral-900">View →</a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    ) : (
      <div class="bg-white border border-neutral-200 rounded-xl p-8 text-center text-neutral-500 mb-8">
        No LCA data found for "{titleLabel}" in the current dataset.
      </div>
    )}

    <div class="p-4 bg-neutral-50 rounded-xl border border-neutral-200 text-xs text-neutral-500">
      <strong>Data source:</strong> DOL LCA (Labor Condition Application) public disclosure data, FY2024. Salaries shown are the prevailing wage level at time of LCA filing — actual offer salaries may differ. Data is for informational purposes only.
    </div>

    <div class="mt-6 flex gap-3">
      <a href="/h1b" class="px-5 py-2.5 bg-neutral-900 text-white font-semibold rounded-xl hover:bg-neutral-700 text-sm">← H1B Database</a>
      <a href="/tools/h1b-lottery-calculator" class="px-5 py-2.5 bg-white border border-neutral-200 text-neutral-900 font-semibold rounded-xl hover:border-neutral-800 text-sm">Lottery Odds Calculator →</a>
    </div>
  </div>
</Layout>
